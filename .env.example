# Andrés Valerio · variables de entorno
# Copiar a .env (gitignored) o configurar en Netlify dashboard.

# Google Analytics 4 (formato G-XXXXXXXXXX)
PUBLIC_GA_ID=

# Microsoft Clarity (formato xxxxxxxxxx)
PUBLIC_MICROSOFT_CLARITY_ID=

# Google Search Console verification meta tag
PUBLIC_GSC_VERIFICATION=

# WhatsApp Business number
PUBLIC_WHATSAPP=

# Email de contacto
PUBLIC_CONTACT_EMAIL=
