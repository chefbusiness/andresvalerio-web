---
import BaseLayout from '@layouts/BaseLayout.astro';
import CtaFinal from '@components/CtaFinal.astro';
import BestiaFireBanner from '@components/BestiaFireBanner.astro';
import { proyectos } from '@data/proyectos';
---

<BaseLayout
  title="Proyectos · Andrés Valerio"
  description="Los negocios de Andrés Valerio: Valerio Burger Club, Burger Master Academy, Catering Fast Good y Bestia Fire (Parrilla & Events)."
  canonicalPath="/proyectos/"
>
  <section class="proy-hero">
    <div class="container">
      <span class="eyebrow rv">Proyectos</span>
      <h1 class="rv d1">Lo que Andrés tiene abierto</h1>
      <p class="lead rv d2">
        No solo asesoro: opero. Estos son los negocios donde la cocina de producto,
        el fuego y la hamburguesa de autor se viven cada día.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="proy-grid">
        {proyectos.map((p, i) => (
          <a href={`/proyectos/${p.slug}/`} class:list={['proy-card', 'rv', `d${(i % 4) + 1}`]}>
            <div class="proy-media">
              {p.imagen
                ? <img src={p.imagen} alt={`${p.nombre} — Andrés Valerio`} width="1000" height="1250" loading="lazy" />
                : <span class="proy-media-fallback" aria-hidden="true">{p.nombre}</span>}
              <span class="proy-estado font-mono">{p.estado}</span>
            </div>
            <div class="proy-body">
              <span class="proy-cat font-mono">{p.categoria}</span>
              <h2>{p.nombre}</h2>
              <p>{p.resumen}</p>
              <span class="proy-arrow">Ver proyecto →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <BestiaFireBanner variant="inline" context="projects" bgImage="/bestia-fire/banner.jpg" />

  <CtaFinal
    title="¿Una idea para tu próximo negocio?"
    text="El mismo chef que opera estos proyectos puede ayudarte con el tuyo."
  />
</BaseLayout>

<style>
  .proy-hero {
    background: var(--teal);
    color: var(--bone);
    padding: calc(72px + clamp(2.5rem, 7vw, 5rem)) 0 clamp(2.5rem, 6vw, 4rem);
  }
  .proy-hero .eyebrow { color: var(--brass); }
  .proy-hero .eyebrow::before { background: var(--brass); }
  .proy-hero h1 {
    font-size: clamp(2.6rem, 7vw, 5rem);
    margin: 0.3em 0 0.4em;
    color: var(--bone);
    line-height: 1;
  }
  .proy-hero .lead { color: var(--bone-soft); max-width: 56ch; }

  .proy-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.75rem;
  }
  @media (min-width: 720px) {
    .proy-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .proy-card {
    display: flex;
    flex-direction: column;
    background: var(--paper);
    border: 1px solid var(--line-light);
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s;
  }
  .proy-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 28px 56px -32px rgba(22, 36, 31, 0.45);
    border-color: rgba(221, 84, 48, 0.5);
  }

  .proy-media {
    position: relative;
    aspect-ratio: 16 / 10;
    background: linear-gradient(150deg, var(--teal), var(--teal-2, #16413C));
    overflow: hidden;
  }
  .proy-media img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .proy-media-fallback {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 1.5rem;
    font-family: var(--font-display);
    font-size: 1.6rem;
    color: var(--bone-soft);
  }
  .proy-media-fallback::after {
    content: "";
    position: absolute;
    top: -30%;
    right: -10%;
    width: 60%;
    height: 140%;
    background: radial-gradient(circle, rgba(221, 84, 48, 0.3), transparent 65%);
    pointer-events: none;
  }
  .proy-estado {
    position: absolute;
    top: 14px;
    left: 14px;
    z-index: 1;
    background: var(--pers);
    color: #fff;
    font-size: 0.64rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.4em 0.8em;
    border-radius: 3px;
  }

  .proy-body { padding: 1.75rem; display: flex; flex-direction: column; flex: 1; }
  .proy-cat {
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--pers-deep);
  }
  .proy-body h2 { font-size: 1.65rem; margin: 0.4rem 0 0.6rem; color: var(--ink); }
  .proy-body p { font-size: 1rem; color: var(--ink-soft); }
  .proy-arrow {
    margin-top: 1.25rem;
    color: var(--pers);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: transform 0.25s;
  }
  .proy-card:hover .proy-arrow { transform: translateX(6px); }

  .bg-teal { background: var(--teal); color: var(--bone); }
  .bg-teal :global(h2) { color: var(--bone); }
  .final {
    text-align: center;
    background: radial-gradient(70% 120% at 50% 0%, rgba(221, 84, 48, 0.2), transparent 60%), var(--teal);
  }
  .cta-center { display: flex; flex-direction: column; align-items: center; }
  .cta-center h2 { font-size: clamp(2rem, 4.6vw, 3.2rem); margin: 0.3em 0 0; color: var(--bone); }
  .cta-center .lead { margin: 1rem auto 0; color: var(--bone-soft); max-width: 46ch; }
  .cta-center .btn-primary { margin-top: 2rem; }
  .eyebrow.light { color: var(--pers); }
  .eyebrow.light::before { background: var(--pers); }
  .eyebrow.center { justify-content: center; }
  .eyebrow.center::before { display: none; }
</style>

<script>
  import { initReveal } from '@utils/reveal';
  initReveal();
</script>
