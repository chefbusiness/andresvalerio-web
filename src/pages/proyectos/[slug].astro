---
import BaseLayout from '@layouts/BaseLayout.astro';
import CtaFinal from '@components/CtaFinal.astro';
import { proyectos } from '@data/proyectos';

export function getStaticPaths() {
  return proyectos.map((p) => ({ params: { slug: p.slug }, props: { p } }));
}

const { p } = Astro.props;
const otros = proyectos.filter((x) => x.slug !== p.slug);
---

<BaseLayout
  title={`${p.nombre} · Proyectos · Andrés Valerio`}
  description={p.resumen}
  canonicalPath={`/proyectos/${p.slug}/`}
>
  <section class:list={['proj-hero', { 'has-photo': p.imagen }]}>
    {p.imagen && <div class="proj-hero-photo" style={`background-image:url(${p.imagen})`} aria-hidden="true"></div>}
    <div class="proj-hero-scrim" aria-hidden="true"></div>
    <div class="container">
      <p class="crumb font-mono rv"><a href="/proyectos/">Proyectos</a> &nbsp;/&nbsp; <strong>{p.nombre}</strong></p>
      <span class="eyebrow rv d1">{p.categoria}</span>
      <h1 class="rv d2">{p.nombre}</h1>
      <p class="lead rv d3">{p.resumen}</p>
      <div class="hero-ctas rv d4">
        {p.externo
          ? <a href={p.externo} target="_blank" rel="noopener noreferrer" class="btn-primary">Visitar {p.nombre} →</a>
          : <a href="/contacto/" class="btn-primary">Quiero saber más →</a>}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <span class="proj-note font-mono rv">Contenido ampliado en preparación</span>
      <div class="hl-grid">
        {p.highlights.map((h, i) => (
          <div class:list={['hl', 'rv', `d${(i % 3) + 1}`]}>
            <span class="hl-n font-mono">{String(i + 1).padStart(2, '0')}</span>
            <p>{h}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-teal">
    <div class="container">
      <div class="sec-head rv">
        <span class="eyebrow light">Sigue explorando</span>
        <h2>Otros proyectos de Andrés</h2>
      </div>
      <div class="otros-grid">
        {otros.map((o, i) => (
          <a href={`/proyectos/${o.slug}/`} class:list={['otro-card', 'rv', `d${(i % 3) + 1}`]}>
            <span class="otro-cat font-mono">{o.categoria}</span>
            <h3>{o.nombre}</h3>
            <span class="otro-arrow">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CtaFinal
    title="¿Tienes un proyecto en mente?"
    text="Cuéntame qué necesitas y te preparo una propuesta a medida."
  />
</BaseLayout>

<style>
  .proj-hero {
    position: relative;
    isolation: isolate;
    display: flex;
    align-items: center;
    min-height: clamp(56vh, 64vh, 620px);
    padding: calc(72px + clamp(2.5rem, 6vw, 4.5rem)) 0 clamp(2.5rem, 6vw, 4rem);
    background: var(--teal);
    color: var(--bone);
    overflow: hidden;
  }
  .proj-hero-photo {
    position: absolute;
    inset: 0;
    z-index: -2;
    background-size: cover;
    background-position: center;
  }
  .proj-hero-scrim {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(100deg, rgba(13,42,39,0.92) 0%, rgba(13,42,39,0.72) 36%, rgba(13,42,39,0.32) 70%, rgba(13,42,39,0.1) 100%),
      linear-gradient(180deg, rgba(13,42,39,0.2), rgba(13,42,39,0.6));
  }
  .crumb { font-size: 0.72rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--bone-soft); margin-bottom: 24px; }
  .crumb a { color: var(--bone-soft); }
  .crumb a:hover { color: var(--pers); }
  .crumb strong { color: var(--pers); font-weight: 500; }
  .proj-hero .eyebrow { color: var(--brass); }
  .proj-hero .eyebrow::before { background: var(--brass); }
  .proj-hero h1 {
    font-size: clamp(2.6rem, 7vw, 5rem);
    margin: 0.3em 0 0.4em;
    color: var(--bone);
    line-height: 1;
    text-shadow: 0 2px 24px rgba(13,42,39,0.45);
  }
  .proj-hero .lead { color: var(--bone-soft); max-width: 56ch; }
  .hero-ctas { margin-top: 38px; }

  .proj-note {
    display: inline-block;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--pers-deep);
    border: 1px solid var(--line-light);
    border-radius: 999px;
    padding: 0.5em 1em;
    margin-bottom: 2.5rem;
  }
  .hl-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 720px) { .hl-grid { grid-template-columns: repeat(3, 1fr); } }
  .hl {
    background: var(--paper);
    border: 1px solid var(--line-light);
    border-radius: 8px;
    padding: 2rem 1.75rem;
  }
  .hl-n { font-size: 0.72rem; color: var(--pers-deep); letter-spacing: 0.1em; }
  .hl p { margin-top: 0.75rem; font-size: 1.1rem; color: var(--ink); }

  .bg-teal { background: var(--teal); color: var(--bone); }
  .bg-teal :global(h2) { color: var(--bone); }
  .sec-head { max-width: 60ch; margin-bottom: clamp(32px, 5vw, 56px); }
  .sec-head h2 { font-size: clamp(2rem, 4.4vw, 3.2rem); margin: 0.3em 0 0; }
  .eyebrow.light { color: var(--pers); }
  .eyebrow.light::before { background: var(--pers); }
  .eyebrow.center { justify-content: center; }
  .eyebrow.center::before { display: none; }

  .otros-grid { display: grid; grid-template-columns: 1fr; gap: 1.25rem; }
  @media (min-width: 720px) { .otros-grid { grid-template-columns: repeat(3, 1fr); } }
  .otro-card {
    display: block;
    background: var(--teal-2, #16413C);
    border: 1px solid var(--line-dark);
    border-radius: 10px;
    padding: 1.75rem;
    text-decoration: none;
    color: var(--bone);
    transition: transform 0.25s, border-color 0.25s;
  }
  .otro-card:hover { transform: translateY(-4px); border-color: rgba(221,84,48,0.5); }
  .otro-cat { font-size: 0.68rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--pers); }
  .otro-card h3 { font-size: 1.3rem; margin-top: 0.5rem; color: var(--bone); }
  .otro-arrow { display: inline-block; margin-top: 0.85rem; color: var(--pers); font-size: 1.2rem; }

  .final { text-align: center; background: radial-gradient(70% 120% at 50% 0%, rgba(221,84,48,0.2), transparent 60%), var(--teal); }
  .cta-center { display: flex; flex-direction: column; align-items: center; }
  .cta-center h2 { font-size: clamp(2rem, 4.6vw, 3.2rem); margin: 0.3em 0 0; color: var(--bone); }
  .cta-center .lead { margin: 1rem auto 0; color: var(--bone-soft); max-width: 46ch; }
  .cta-center .btn-primary { margin-top: 2rem; }
</style>

<script>
  import { initReveal } from '@utils/reveal';
  initReveal();
</script>
