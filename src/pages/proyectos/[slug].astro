---
import BaseLayout from '@layouts/BaseLayout.astro';
import CtaFinal from '@components/CtaFinal.astro';
import { proyectos } from '@data/proyectos';
import { proyectosContenido } from '@data/proyectos-contenido';

export function getStaticPaths() {
  return proyectos.map((p) => ({ params: { slug: p.slug }, props: { p } }));
}

const { p } = Astro.props;
const c = proyectosContenido[p.slug];
const otros = proyectos.filter((x) => x.slug !== p.slug);
const heroTitle = c?.heroTitle ?? p.nombre;
const heroLead = c?.heroLead ?? p.resumen;
---

<BaseLayout
  title={c?.metaTitle ?? `${p.nombre} · Proyectos · Andrés Valerio`}
  description={c?.metaDescription ?? p.resumen}
  canonicalPath={`/proyectos/${p.slug}/`}
>
  <section class:list={['proj-hero', { 'has-photo': p.imagen }]}>
    {p.imagen && <div class="proj-hero-photo" style={`background-image:url(${p.imagen})`} aria-hidden="true"></div>}
    <div class="proj-hero-scrim" aria-hidden="true"></div>
    <div class="container">
      <p class="crumb font-mono rv"><a href="/proyectos/">Proyectos</a> &nbsp;/&nbsp; <strong>{p.nombre}</strong></p>
      <span class="eyebrow rv d1">{p.categoria}</span>
      <h1 class="rv d2">{heroTitle}</h1>
      <p class="lead rv d3">{heroLead}</p>
      <div class="hero-ctas rv d4">
        {p.externo
          ? <a href={p.externo} target="_blank" rel="noopener noreferrer" class="btn-primary">Visitar {p.nombre} →</a>
          : <a href="/contacto/" class="btn-primary">Pedir presupuesto →</a>}
      </div>
    </div>
  </section>

  {c ? (
    <>
      <!-- INTRO -->
      <section class="section">
        <div class="container intro-block rv">
          {c.intro.map((par) => <p>{par}</p>)}
        </div>
      </section>

      {p.galeria && p.galeria.length > 0 && (
        <figure class="ctx-band">
          <img src={p.galeria[0]} alt={`${p.nombre} — ${p.categoria}`} width="1600" height="893" loading="lazy" />
        </figure>
      )}

      <!-- PARA QUIÉN -->
      <section class="section bg-teal">
        <div class="container">
          <div class="sec-head rv">
            <span class="eyebrow light">Para quién</span>
            <h2>Pensado para tu evento</h2>
          </div>
          <div class="pq-grid">
            {c.paraQuien.map((x, i) => (
              <div class:list={['pq', 'rv', `d${(i % 4) + 1}`]}>
                <span class="pq-n font-mono">{String(i + 1).padStart(2, '0')}</span>
                <h3>{x.titulo}</h3>
                <p>{x.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- FORMATOS -->
      <section class="section">
        <div class="container">
          <div class="sec-head rv">
            <span class="eyebrow">Experiencias</span>
            <h2>Formatos de parrilla a elegir</h2>
          </div>
          <div class="fmt-grid">
            {c.formatos.map((f, i) => (
              <div class:list={['fmt', 'rv', `d${(i % 3) + 1}`]}>
                <h3>{f.nombre}</h3>
                <p>{f.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- QUÉ INCLUYE -->
      <section class="section bg-teal">
        <div class="container incluye-grid">
          <div class="rv">
            <span class="eyebrow light">Qué incluye</span>
            <h2>Servicio completo, llave en mano</h2>
          </div>
          <ul class="incluye-list rv d1">
            {c.queIncluye.map((item) => (
              <li>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M4 12.5l5 5 11-11.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </section>

      <!-- GALERÍA -->
      {p.galeria && p.galeria.length > 1 && (
        <section class="section">
          <div class="container">
            <div class="sec-head rv">
              <span class="eyebrow">Galería</span>
              <h2>El fuego en acción</h2>
            </div>
            <div class="gal-grid">
              {p.galeria.map((src, i) => (
                <figure class:list={['gal', 'rv', `d${(i % 3) + 1}`]}>
                  <img src={src} alt={`${p.nombre} — imagen ${i + 1}`} width="1600" height="893" loading="lazy" />
                </figure>
              ))}
            </div>
          </div>
        </section>
      )}

      <!-- FAQ -->
      <section class="section bg-teal">
        <div class="container">
          <div class="sec-head rv">
            <span class="eyebrow light">Preguntas frecuentes</span>
            <h2>Lo que suelen preguntarnos</h2>
          </div>
          <div class="faq rv">
            {c.faq.map((f) => (
              <details class="q">
                <summary>{f.q}<span class="pm" aria-hidden="true"></span></summary>
                <p>{f.a}</p>
              </details>
            ))}
          </div>
        </div>
      </section>

      {p.sitioProximamente && (
        <section class="section">
          <div class="container proximamente rv">
            <span class="prox-tag font-mono">Próximamente</span>
            <p>{p.nombre} tendrá su propia web dedicada. Mientras tanto, escríbenos y reservamos la fecha de tu evento.</p>
            <a class="btn-dark is-disabled" aria-disabled="true" title="Web dedicada en preparación">Web dedicada (próximamente)</a>
          </div>
        </section>
      )}
    </>
  ) : (
    <section class="section">
      <div class="container">
        <span class="proj-note font-mono rv">Contenido ampliado en preparación</span>
        <div class="hl-grid">
          {p.highlights.map((h, i) => (
            <div class:list={['hl', 'rv', `d${(i % 3) + 1}`]}>
              <span class="hl-n font-mono">{String(i + 1).padStart(2, '0')}</span>
              <p>{h}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="section">
    <div class="container">
      <div class="sec-head rv">
        <span class="eyebrow">Sigue explorando</span>
        <h2>Otros proyectos de Andrés</h2>
      </div>
      <div class="otros-grid">
        {otros.map((o, i) => (
          <a href={`/proyectos/${o.slug}/`} class:list={['otro-card', 'rv', `d${(i % 3) + 1}`]}>
            <span class="otro-cat font-mono">{o.categoria}</span>
            <h3>{o.nombre}</h3>
            <span class="otro-arrow">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CtaFinal title="¿Tienes un evento en mente?" text="Cuéntanos la fecha, el lugar y cuántos invitados, y te preparamos una propuesta a medida." ctaLabel="Pedir presupuesto" />
</BaseLayout>

<style>
  .proj-hero {
    position: relative;
    isolation: isolate;
    display: flex;
    align-items: center;
    min-height: clamp(56vh, 64vh, 620px);
    padding: calc(72px + clamp(2.5rem, 6vw, 4.5rem)) 0 clamp(2.5rem, 6vw, 4rem);
    background: var(--teal);
    color: var(--bone);
    overflow: hidden;
  }
  @media (max-width: 640px) { .proj-hero { min-height: clamp(52vh, 60vh, 520px); } }
  .proj-hero-photo { position: absolute; inset: 0; z-index: -2; background-size: cover; background-position: center; }
  .proj-hero-scrim {
    position: absolute; inset: 0; z-index: -1;
    background:
      linear-gradient(100deg, rgba(13,42,39,0.92) 0%, rgba(13,42,39,0.72) 36%, rgba(13,42,39,0.34) 70%, rgba(13,42,39,0.12) 100%),
      linear-gradient(180deg, rgba(13,42,39,0.2), rgba(13,42,39,0.6));
  }
  .crumb { font-size: 0.72rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--bone-soft); margin-bottom: 24px; }
  .crumb a { color: var(--bone-soft); }
  .crumb a:hover { color: var(--pers); }
  .crumb strong { color: var(--pers); font-weight: 500; }
  .proj-hero .eyebrow { color: var(--brass); }
  .proj-hero .eyebrow::before { background: var(--brass); }
  .proj-hero h1 { font-size: clamp(2.4rem, 6.5vw, 5rem); margin: 0.3em 0 0.4em; color: var(--bone); line-height: 1; text-shadow: 0 2px 24px rgba(13,42,39,0.45); }
  .proj-hero .lead { color: var(--bone-soft); max-width: 56ch; }
  .hero-ctas { margin-top: 38px; }

  .intro-block { max-width: 70ch; }
  .intro-block p { font-size: clamp(1.05rem, 1.7vw, 1.25rem); color: var(--ink-soft); line-height: 1.75; }
  .intro-block p + p { margin-top: 1.25rem; }

  .ctx-band { margin: 0; overflow: hidden; }
  .ctx-band img { width: 100%; height: clamp(280px, 44vh, 520px); object-fit: cover; display: block; }

  .bg-teal { background: var(--teal); color: var(--bone); }
  .bg-teal :global(h2) { color: var(--bone); }
  .sec-head { max-width: 60ch; margin-bottom: clamp(32px, 5vw, 56px); }
  .sec-head h2 { font-size: clamp(2rem, 4.4vw, 3.2rem); margin: 0.3em 0 0; }
  .eyebrow.light { color: var(--pers); }
  .eyebrow.light::before { background: var(--pers); }

  .pq-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(230px, 1fr)); gap: 1px; background: var(--line-dark); border: 1px solid var(--line-dark); }
  .pq { background: var(--teal-2, #16413C); padding: 32px 28px; }
  .pq-n { font-size: 0.72rem; color: var(--pers); letter-spacing: 0.1em; }
  .pq h3 { font-size: 1.35rem; margin: 12px 0 8px; color: var(--bone); }
  .pq p { font-size: 0.98rem; color: var(--bone-soft); }

  .fmt-grid { display: grid; grid-template-columns: 1fr; gap: 1.25rem; }
  @media (min-width: 640px) { .fmt-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 980px) { .fmt-grid { grid-template-columns: repeat(3, 1fr); } }
  .fmt { background: var(--paper); border: 1px solid var(--line-light); border-radius: 8px; padding: 1.6rem 1.5rem; transition: transform 0.25s, border-color 0.25s; }
  .fmt:hover { transform: translateY(-4px); border-color: rgba(221,84,48,0.45); }
  .fmt h3 { font-size: 1.2rem; color: var(--ink); }
  .fmt p { margin-top: 0.5rem; font-size: 0.96rem; color: var(--ink-soft); }

  .incluye-grid { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 768px) { .incluye-grid { grid-template-columns: 1fr 1.4fr; gap: 4rem; align-items: start; } }
  .incluye-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 1rem; }
  .incluye-list li { display: flex; gap: 0.85rem; align-items: flex-start; color: var(--bone-soft); font-size: 1rem; }
  .incluye-list svg { color: var(--brass); flex-shrink: 0; margin-top: 1px; }

  .gal-grid { display: grid; grid-template-columns: 1fr; gap: 1.25rem; }
  @media (min-width: 720px) { .gal-grid { grid-template-columns: repeat(3, 1fr); } }
  .gal { margin: 0; border-radius: 10px; overflow: hidden; border: 1px solid var(--line-light); aspect-ratio: 4/3; }
  .gal img { width: 100%; height: 100%; object-fit: cover; display: block; }

  .faq { max-width: 820px; border-top: 1px solid rgba(243,236,221,0.2); }
  .q { border-bottom: 1px solid rgba(243,236,221,0.2); }
  .q summary { list-style: none; cursor: pointer; padding: 22px 0; font-family: var(--font-display); font-size: clamp(1.2rem, 2vw, 1.5rem); color: var(--bone); display: flex; justify-content: space-between; align-items: center; gap: 20px; }
  .q summary::-webkit-details-marker { display: none; }
  .q .pm { flex-shrink: 0; width: 28px; height: 28px; border: 1px solid rgba(243,236,221,0.3); border-radius: 50%; position: relative; }
  .q .pm::before, .q .pm::after { content: ""; position: absolute; background: var(--pers); top: 50%; left: 50%; transform: translate(-50%,-50%); transition: 0.3s; }
  .q .pm::before { width: 11px; height: 2px; }
  .q .pm::after { width: 2px; height: 11px; }
  .q[open] .pm::after { opacity: 0; }
  .q p { padding: 0 0 22px; color: var(--bone-soft); max-width: 65ch; }

  .proximamente { text-align: center; display: flex; flex-direction: column; align-items: center; gap: 1rem; }
  .prox-tag { font-size: 0.7rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--pers-deep); border: 1px solid var(--line-light); border-radius: 999px; padding: 0.5em 1.1em; }
  .proximamente p { color: var(--ink-soft); max-width: 50ch; }
  .btn-dark.is-disabled { opacity: 0.5; pointer-events: none; cursor: default; }

  .proj-note { display: inline-block; font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--pers-deep); border: 1px solid var(--line-light); border-radius: 999px; padding: 0.5em 1em; margin-bottom: 2.5rem; }
  .hl-grid { display: grid; grid-template-columns: 1fr; gap: 1.5rem; }
  @media (min-width: 720px) { .hl-grid { grid-template-columns: repeat(3, 1fr); } }
  .hl { background: var(--paper); border: 1px solid var(--line-light); border-radius: 8px; padding: 2rem 1.75rem; }
  .hl-n { font-size: 0.72rem; color: var(--pers-deep); letter-spacing: 0.1em; }
  .hl p { margin-top: 0.75rem; font-size: 1.1rem; color: var(--ink); }

  .otros-grid { display: grid; grid-template-columns: 1fr; gap: 1.25rem; }
  @media (min-width: 720px) { .otros-grid { grid-template-columns: repeat(3, 1fr); } }
  .otro-card { display: block; background: var(--paper); border: 1px solid var(--line-light); border-radius: 10px; padding: 1.75rem; text-decoration: none; color: inherit; transition: transform 0.25s, border-color 0.25s; }
  .otro-card:hover { transform: translateY(-4px); border-color: var(--brass); }
  .otro-cat { font-size: 0.68rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--pers-deep); }
  .otro-card h3 { font-size: 1.3rem; margin-top: 0.5rem; color: var(--ink); }
  .otro-arrow { display: inline-block; margin-top: 0.85rem; color: var(--pers); font-size: 1.2rem; }
</style>

<script>
  import { initReveal } from '@utils/reveal';
  initReveal();
</script>
