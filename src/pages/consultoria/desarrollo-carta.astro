    transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
  }
  .related-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(22, 36, 31, 0.08);
    border-color: var(--brass, #BC9248);
  }
  .related-card h3 { font-size: 1.15rem; }
  .related-card p { margin-top: 0.5rem; font-size: 0.9rem; color: var(--ink-soft, #5C6A60); }
  .related-arrow { color: var(--pers, #DD5430); font-size: 1.2rem; display: inline-block; margin-top: 0.75rem; }
</style>

<script>
  import { initReveal } from '@utils/reveal';

  initReveal();

  document.querySelectorAll('.q button').forEach((b) => {
    b.addEventListener('click', () => {
      const q = b.parentElement;
      const a = q.querySelector('.a');
      const open = q.classList.contains('open');

      document.querySelectorAll('.q').forEach((x) => {
        x.classList.remove('open');
        (x.querySelector('.a') as HTMLElement).style.maxHeight = '';
      });

      if (!open) {
        q.classList.add('open');
        (a as HTMLElement).style.maxHeight = a.scrollHeight + 'px';
      }
    });
  });
</script>
