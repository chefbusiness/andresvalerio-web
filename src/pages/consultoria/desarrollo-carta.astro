---
import BaseLayout from '@layouts/BaseLayout.astro';
import { serviceSchema, faqSchema } from '@utils/schema';

const data = {
  hero: { eyebrow: 'Desarrollo y renovación de carta', h1: 'Desarrollo y renovación de carta' },
  meta_description:
    'Diseño, desarrollo y estandarización de platos para restaurantes, grupos y hoteles en República Dominicana: escandallos, fichas técnicas, costos y entrenamiento del equipo.',
  faq: [
    { q: '¿Necesito un diagnóstico previo?', a: 'No siempre. Si el encargo está claro —renovar o crear platos concretos— vamos directos a la propuesta. El diagnóstico es para cuando el problema aún no tiene alcance definido.' },
    { q: '¿Trabajas fuera de Santo Domingo?', a: 'Sí. Trabajo en Santiago, Punta Cana y otras zonas de turismo. El desplazamiento y la logística se presupuestan aparte según la ubicación.' },
    { q: '¿Cuánto tarda el proceso?', a: 'Una renovación de sección suele cerrarse en dos o tres semanas, según el número de platos y la disponibilidad de insumos para las demos.' },
    { q: '¿Qué pasa con los insumos de las demos?', a: 'El costo de los ingredientes para preparar las muestras corre por cuenta del cliente y se coordina antes de empezar. Mis honorarios cubren el desarrollo, la documentación y el entrenamiento.' },
  ],
};

const pricingRows = [
  { modalidad: 'Plato individual', alcance: '1 plato completo', rd: '11,000', us: '185' },
  { modalidad: 'Renovación de sección', alcance: 'hasta 5 platos + entrenamiento', rd: '48,000', us: '800' },
  { modalidad: 'Carta completa', alcance: 'hasta 12 platos', rd: '96,000', us: '1,600' },
];
---

<BaseLayout
  title="Desarrollo y renovación de carta · Andrés Valerio"
  description="Diseño, desarrollo y estandarización de platos para restaurantes, grupos y hoteles en República Dominicana. Del concepto al pase: escandallos, fichas técnicas, costos y entrenamiento del equipo."
  image="/og/og-default.jpg"
  canonicalPath="/consultoria/desarrollo-carta/"
>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={serviceSchema(data, 'desarrollo-carta', pricingRows)} />
    <script type="application/ld+json" is:inline set:html={faqSchema(data.faq)} />
  </Fragment>
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-scrim"></div>
    <div class="container">
      <p class="crumb rv">Consultoría &nbsp;/&nbsp; <strong>Desarrollo de carta</strong></p>
      <p class="eyebrow rv d1">Desarrollo y renovación de carta</p>
      <h1 class="rv d2">Platos nuevos, con <em>técnica</em>, costos y equipo listos para el pase.</h1>
      <p class="lead rv d3">Diseño, desarrollo y estandarización de platos para restaurantes, grupos y hoteles en República Dominicana. De la idea al servicio: escandallos, fichas técnicas, estructura de costos y entrenamiento de tu equipo.</p>
      <div class="hero-actions rv d4">
        <a href="#contacto" class="btn btn-primary">Solicitar propuesta <span class="ar">→</span></a>
        <a href="#metodo" class="btn btn-ghost">Ver cómo trabajo ↓</a>
      </div>
      <div class="hero-trust rv d4">
        <span class="trust-mark">Chef · Consultor</span>
        <span>Chef-propietario de Valerio Burger Club</span>
        <span class="dot"></span>
        <span>Santo Domingo · Santiago · Punta Cana</span>
      </div>
    </div>
  </section>

  <section class="dark sec-pad">
    <div class="container">
      <div class="sec-head rv">
        <p class="eyebrow">Para quién</p>
        <h2>Pensado para quien vive del producto.</h2>
        <p class="lead">No es teoría de manual. Es desarrollo gastronómico real, con números y ejecución, para operadores que necesitan que el plato funcione en cocina y en caja.</p>
      </div>
      <div class="aud-grid">
        <div class="aud rv">
          <span class="n">01</span>
          <h3>Restaurantes</h3>
          <p>Que quieren refrescar su carta, subir el ticket medio o recuperar márgenes sin perder identidad.</p>
        </div>
        <div class="aud rv d1">
          <span class="n">02</span>
          <h3>Grupos y franquicias</h3>
          <p>Que necesitan estandarizar platos para replicarlos igual en varios locales.</p>
        </div>
        <div class="aud rv d2">
          <span class="n">03</span>
          <h3>Hoteles y turismo</h3>
          <p>Operadores en Punta Cana y zonas de playa que buscan propuestas de autor escalables.</p>
        </div>
        <div class="aud rv d3">
          <span class="n">04</span>
          <h3>Industria de alimentos</h3>
          <p>Marcas que desarrollan producto y necesitan recetas, fichas técnicas y costos profesionales.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="light sec-pad" id="metodo">
    <div class="container">
      <div class="sec-head rv">
        <p class="eyebrow">El método</p>
        <h2>De la idea al pase, en seis pasos.</h2>
        <p class="lead">Cada plato pasa por el mismo proceso. Tú apruebas antes de que se cocine nada, y al final tu equipo lo ejecuta solo.</p>
      </div>
      <div class="steps">
        <div class="step rv">
          <div class="num">01 · Propuesta <span class="bar"></span></div>
          <h3>Propuesta</h3>
          <p>Definimos alcance y concepto. Te envío una propuesta con los platos, el enfoque y el presupuesto. Tú apruebas antes de cocinar.</p>
        </div>
        <div class="step rv d1">
          <div class="num">02 · Demos <span class="bar"></span></div>
          <h3>Demos de los platos</h3>
          <p>Preparo las muestras reales de cada plato para que las pruebes y ajustemos sabor, textura y presentación juntos.</p>
        </div>
        <div class="step rv">
          <div class="num">03 · Escandallos <span class="bar"></span></div>
          <h3>Escandallos</h3>
          <p>Cada plato con su escandallo: costo real por ingrediente, porción y merma. Saber exactamente cuánto cuesta cada bocado.</p>
        </div>
        <div class="step rv d1">
          <div class="num">04 · Fichas técnicas <span class="bar"></span></div>
          <h3>Fichas técnicas</h3>
          <p>Receta estandarizada, gramajes, montaje y foto. Para que cualquier cocinero lo replique idéntico, cada vez.</p>
        </div>
        <div class="step rv">
          <div class="num">05 · Costos <span class="bar"></span></div>
          <h3>Estructura de costos</h3>
          <p>Food cost objetivo, precio de venta sugerido y margen por plato. Decisiones con números, no a ojo.</p>
        </div>
        <div class="step rv d1">
          <div class="num">06 · Equipo <span class="bar"></span></div>
          <h3>Entrenamiento del equipo</h3>
          <p>Capacito a tu equipo en el pase real, hasta que el plato sale perfecto sin que yo esté en la cocina.</p>
        </div>
      </div>
      <p class="method-note rv">"No te entrego un PDF y me voy. El mismo chef que diseña el plato es el que entrena a tu equipo para ejecutarlo."</p>
    </div>
  </section>

  <figure class="ctx-band">
    <img src="/images/contexto/escandallos.jpg" alt="Cuaderno de recetas junto a una hoja de escandallo de costos sobre una tabla de madera" width="1600" height="900" loading="lazy" />
  </figure>

  <section class="dark sec-pad">
    <div class="container">
      <div class="case rv">
        <p class="eyebrow">Un encargo típico</p>
        <p class="case-quote">"Un cliente vuelve tres años después: quiere renovar dos hamburguesas e incorporar tres o cuatro nachos nuevos."</p>
        <div class="case-flow">
          <span class="chip on">Propuesta</span>
          <span class="chip">→</span>
          <span class="chip on">Demos</span>
          <span class="chip">→</span>
          <span class="chip on">Escandallos</span>
          <span class="chip">→</span>
          <span class="chip on">Fichas técnicas</span>
          <span class="chip">→</span>
          <span class="chip on">Costos</span>
          <span class="chip">→</span>
          <span class="chip on">Entrenamiento</span>
        </div>
        <p>Levanto la propuesta y la apruebas. Preparo las demos de cada plato y las afinamos. Documento <strong>escandallos y fichas técnicas</strong>, monto la estructura de costos y, por último, entreno al equipo que lo va a ejecutar. En <strong>dos o tres semanas</strong> su carta tiene platos nuevos, costeados y un equipo que los borda igual cada día.</p>
      </div>
    </div>
  </section>

  <section class="alt sec-pad" id="precios">
    <div class="container">
      <div class="sec-head rv">
        <p class="eyebrow">Modalidades</p>
        <h2>Precios de referencia.</h2>
        <p class="lead">Tarifas orientativas en pesos (RD$) y dólares (US$), para clientes locales y extranjeros en República Dominicana. Cada proyecto se cierra con un presupuesto a medida.</p>
      </div>
      <div class="price-grid">
        <div class="price rv">
          <h3>Plato individual</h3>
          <div class="scope">1 plato · completo</div>
          <div class="amt"><span class="rd">RD$11,000</span><span class="usd">/ US$185</span></div>
          <span class="from">desde</span>
          <p>Un plato de principio a fin: propuesta, demo, escandallo, ficha técnica y costeo.</p>
          <a href="#contacto" class="btn btn-dark">Solicitar</a>
        </div>
        <div class="price feat rv d1">
          <span class="tag">El más solicitado</span>
          <h3>Renovación de sección</h3>
          <div class="scope">hasta 5 platos</div>
          <div class="amt"><span class="rd">RD$48,000</span><span class="usd">/ US$800</span></div>
          <span class="from">desde</span>
          <p>Todo lo anterior para un grupo de platos <strong>más el entrenamiento del equipo</strong>. Es el caso típico de renovación de carta.</p>
          <a href="#contacto" class="btn btn-primary">Solicitar propuesta <span class="ar">→</span></a>
        </div>
        <div class="price rv d2">
          <h3>Carta completa</h3>
          <div class="scope">hasta 12 platos</div>
          <div class="amt"><span class="rd">RD$96,000</span><span class="usd">/ US$1,600</span></div>
          <span class="from">desde</span>
          <p>Rediseño integral de carta, estandarización completa y entrenamiento del equipo.</p>
          <a href="#contacto" class="btn btn-dark">Solicitar</a>
        </div>
        <div class="price rv d3">
          <h3>I+D / A medida</h3>
          <div class="scope">continuo · industria</div>
          <div class="amt"><span class="rd">Presupuesto</span></div>
          <span class="from">personalizado</span>
          <p>Desarrollo continuo de producto para marcas, franquicias e industria de alimentos.</p>
          <a href="#contacto" class="btn btn-dark">Hablemos</a>
        </div>
      </div>
      <p class="price-foot rv">Conversión RD$/US$ aproximada y orientativa. No incluye el costo de los insumos de las demos. Los desplazamientos fuera de Santo Domingo (Santiago, Punta Cana, etc.) se presupuestan aparte.</p>
    </div>
  </section>

  <section class="dark sec-pad">
    <div class="container auth">
      <div class="auth-photo rv">
        <img src="/images/chef/chef-1.jpg" alt="Chef Andrés Valerio en cocina" />
      </div>
      <div class="rv d1">
        <p class="eyebrow">Por qué Andrés Valerio</p>
        <h2 class="auth-title">Un chef que opera, no solo asesora.</h2>
        <ul>
          <li><strong>Chef-propietario de Valerio Burger Club.</strong> Vivo a diario lo mismo que tú: producto, costos, equipo y pase.</li>
          <li><strong>Trayectoria probada.</strong> Dirección culinaria en The Crime y formación de cocineros a través de la Burger Master Academy.</li>
          <li><strong>Quien diseña, ejecuta.</strong> El mismo chef que crea el plato es el que entrena a tu equipo. Sin intermediarios.</li>
          <li><strong>Decisiones con datos.</strong> Escandallos, food cost y márgenes reales en cada plato que toco.</li>
        </ul>
        <p class="pull">Técnica, <span>fuego</span> y números. Así nace un plato que vende.</p>
      </div>
    </div>
  </section>

  <section class="light sec-pad">
    <div class="container">
      <div class="sec-head rv" style="margin-bottom:40px">
        <p class="eyebrow">Preguntas frecuentes</p>
        <h2>Antes de escribirme.</h2>
      </div>
      <div class="faq rv">
        <div class="q">
          <button>¿Necesito un diagnóstico previo?<span class="pm"></span></button>
          <div class="a"><p>No siempre. Si el encargo está claro —renovar o crear platos concretos— vamos directos a la propuesta. El diagnóstico es para cuando el problema aún no tiene alcance definido.</p></div>
        </div>
        <div class="q">
          <button>¿Trabajas fuera de Santo Domingo?<span class="pm"></span></button>
          <div class="a"><p>Sí. Trabajo en Santiago, Punta Cana y otras zonas de turismo. El desplazamiento y la logística se presupuestan aparte según la ubicación.</p></div>
        </div>
        <div class="q">
          <button>¿Cuánto tarda el proceso?<span class="pm"></span></button>
          <div class="a"><p>Una renovación de sección suele cerrarse en dos o tres semanas, según el número de platos y la disponibilidad de insumos para las demos.</p></div>
        </div>
        <div class="q">
          <button>¿Qué pasa con los insumos de las demos?<span class="pm"></span></button>
          <div class="a"><p>El costo de los ingredientes para preparar las muestras corre por cuenta del cliente y se coordina antes de empezar. Mis honorarios cubren el desarrollo, la documentación y el entrenamiento.</p></div>
        </div>
      </div>
    </div>
  </section>

  <section class="light sec-pad">
    <div class="container">
      <div class="sec-head rv">
        <p class="eyebrow">Sigue explorando</p>
        <h2>Otros servicios de consultoría</h2>
      </div>
      <div class="related-grid">
        <a class="related-card rv" href="/consultoria/apertura/">
          <h3>Apertura y concepto</h3>
          <p>Del concepto a la puesta en marcha de tu restaurante.</p>
          <span class="related-arrow">→</span>
        </a>
        <a class="related-card rv d1" href="/consultoria/mentoria/">
          <h3>Mentoría y acompañamiento</h3>
          <p>Sesiones recurrentes para chefs, propietarios y equipos.</p>
          <span class="related-arrow">→</span>
        </a>
        <a class="related-card rv d2" href="/consultoria/diagnostico/">
          <h3>Diagnóstico gastronómico</h3>
          <p>Auditoría 360 con informe y plan de acción priorizado.</p>
          <span class="related-arrow">→</span>
        </a>
        <a class="related-card rv d3" href="/consultoria/">
          <h3>Ver todos los servicios</h3>
          <p>Vuelve al hub de consultoría gastronómica.</p>
          <span class="related-arrow">→</span>
        </a>
      </div>
    </div>
  </section>

  <section class="dark final sec-pad" id="contacto">
    <div class="container">
      <p class="eyebrow center rv" style="justify-content:center">Hablemos</p>
      <h2 class="rv d1">¿Tienes platos en mente?</h2>
      <p class="lead rv d2">Cuéntame qué quieres renovar o crear y te envío una propuesta con alcance y presupuesto.</p>
      <div class="final-actions rv d3">
        <a href="https://wa.me/18098847605" class="btn btn-primary" target="_blank" rel="noopener noreferrer">Escribir por WhatsApp <span class="ar">→</span></a>
        <a href="mailto:hola@andresvalerio.com" class="btn btn-ghost">Enviar un correo</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    min-height: clamp(76vh, 86vh, 820px);
    padding: calc(72px + clamp(40px, 7vw, 96px)) 0 clamp(48px, 8vw, 112px);
    overflow: hidden;
  }

  .hero .container {
    position: relative;
    z-index: 1;
  }

  /* Capa foto de fondo a sangre completa */
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: -2;
    background:
      var(--teal) url("/images/platos/valerio-burger.jpg") center / cover no-repeat;
  }

  /* Scrim teal oscuro: degradado vertical + refuerzo lateral del lado del texto */
  .hero-scrim {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(105deg, rgba(13, 42, 39, 0.86) 0%, rgba(13, 42, 39, 0.62) 42%, rgba(13, 42, 39, 0.28) 100%),
      linear-gradient(180deg, rgba(13, 42, 39, 0.5), rgba(13, 42, 39, 0.84));
  }

  /* Glow persimón sutil sobre la foto */
  .hero-scrim::after {
    content: "";
    position: absolute;
    top: -12%;
    right: -6%;
    width: 48vw;
    height: 48vw;
    max-width: 560px;
    max-height: 560px;
    background: radial-gradient(circle, rgba(221, 84, 48, 0.22), transparent 68%);
    pointer-events: none;
  }

  .crumb {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    color: var(--bone-soft);
    text-transform: uppercase;
    margin-bottom: 26px;
  }

  .crumb strong {
    color: var(--pers);
    font-weight: 500;
  }

  .hero .eyebrow {
    color: var(--brass);
  }

  .hero .eyebrow::before {
    background: var(--brass);
  }

  .hero h1 {
    font-size: clamp(2.7rem, 7vw, 5.6rem);
    max-width: 15ch;
    margin: 0.3em 0 0.5em;
    line-height: 1;
    color: var(--bone);
    text-shadow: 0 2px 24px rgba(13, 42, 39, 0.45);
  }

  .hero h1 em {
    font-style: italic;
    color: #F08A5D;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 38px;
  }

  .hero-trust {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-top: 42px;
    font-size: 0.86rem;
    color: var(--bone-soft);
    flex-wrap: wrap;
  }

  .hero-trust .dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--pers);
  }

  .trust-mark {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--brass);
    border: 1px solid var(--bone-faint);
    padding: 0.35em 0.7em;
    border-radius: 3px;
  }

  .lead {
    font-size: clamp(1.05rem, 1.7vw, 1.28rem);
    color: var(--ink-soft);
    max-width: 54ch;
  }

  .hero .lead {
    color: var(--bone-soft);
    text-shadow: 0 1px 12px rgba(13, 42, 39, 0.4);
  }

  .dark {
    background: var(--teal);
    color: var(--bone);
  }

  .dark .eyebrow {
    color: var(--pers);
  }

  .dark .eyebrow::before {
    background: var(--pers);
  }

  .dark .lead {
    color: var(--bone-soft);
  }

  .light {
    background: var(--bone);
  }

  .alt {
    background: var(--bone-2);
  }

  .sec-pad {
    padding: var(--sec) 0;
  }

  .sec-head {
    max-width: 62ch;
    margin-bottom: clamp(40px, 6vw, 72px);
  }

  .sec-head h2 {
    font-size: clamp(2.2rem, 4.8vw, 3.6rem);
    margin: 0.3em 0 0.4em;
  }

  .aud-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 1px;
    background: var(--line-dark);
    border: 1px solid var(--line-dark);
  }

  .aud {
    background: var(--teal-2);
    padding: 34px 30px;
    transition: background 0.3s;
  }

  .aud:hover {
    background: var(--teal-3);
  }

  .aud .n {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--pers);
    letter-spacing: 0.1em;
  }

  .aud h3 {
    font-size: 1.5rem;
    margin: 14px 0 8px;
    color: var(--bone);
  }

  .aud p {
    font-size: 0.92rem;
    color: var(--bone-soft);
  }

  .steps {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .step {
    background: var(--paper);
    border: 1px solid var(--line-light);
    border-radius: 6px;
    padding: 32px 30px;
    position: relative;
    transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s;
  }

  .step:hover {
    transform: translateY(-4px);
    box-shadow: 0 24px 50px -30px rgba(22, 36, 31, 0.4);
    border-color: rgba(221, 84, 48, 0.45);
  }

  .step .num {
    font-family: var(--font-mono);
    font-size: 0.76rem;
    font-weight: 600;
    color: var(--pers-deep);
    letter-spacing: 0.14em;
    display: flex;
    align-items: center;
    gap: 10px;
    text-transform: uppercase;
  }

  .step .num .bar {
    flex: 1;
    height: 1px;
    background: var(--line-light);
  }

  .step h3 {
    font-size: 1.7rem;
    margin: 16px 0 8px;
    color: var(--ink);
  }

  .step p {
    font-size: 0.96rem;
    color: var(--ink-soft);
  }

  .ctx-band {
    margin: 0;
    overflow: hidden;
  }
  .ctx-band img {
    width: 100%;
    height: clamp(280px, 44vh, 520px);
    object-fit: cover;
    display: block;
  }

  .method-note {
    margin-top: 42px;
    padding: 24px 32px;
    border-left: 3px solid var(--pers);
    background: var(--paper);
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-style: italic;
    color: var(--ink);
    max-width: 62ch;
    line-height: 1.3;
  }

  .case {
    background: var(--teal-2);
    border-radius: 10px;
    padding: clamp(38px, 6vw, 72px);
    position: relative;
    overflow: hidden;
    border: 1px solid var(--line-dark);
  }

  .case::before {
    content: "";
    position: absolute;
    right: -70px;
    top: -70px;
    width: 340px;
    height: 340px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(221, 84, 48, 0.2), transparent 70%);
    pointer-events: none;
  }

  .case-quote {
    font-family: var(--font-display);
    font-size: clamp(1.7rem, 3.4vw, 2.6rem);
    line-height: 1.22;
    color: var(--bone);
    max-width: 26ch;
    position: relative;
    font-style: italic;
  }

