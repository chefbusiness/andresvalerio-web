---
import BaseLayout from '@layouts/BaseLayout.astro';
import ServiceLanding from '@components/ServiceLanding.astro';
import { serviceSchema, faqSchema } from '@utils/schema';
import data from '@data/servicios/diagnostico.json';

const slug = 'diagnostico';

const pricing = {
  title: 'Inversión orientativa',
  rows: [
    {
      modalidad: 'Por proyecto (~21 días)',
      alcance: 'Auditoría 360 (operaciones, costos, carta, equipo) + informe y plan de acción',
      rd: 'desde 33,000',
      us: 'desde 550',
      feat: true,
    },
  ],
  note: 'Conversión aproximada 1 US$ ≈ 60 RD$. Precio orientativo «desde» y ajustable según el tamaño de la operación. El diagnóstico no es obligatorio para contratar otros servicios. Los desplazamientos fuera de Santo Domingo (Santiago, Punta Cana, etc.) se presupuestan aparte.',
};

const related = [
  { label: 'Desarrollo de carta', href: '/consultoria/desarrollo-carta/', desc: 'Platos nuevos con escandallos, fichas técnicas y entrenamiento del equipo.' },
  { label: 'Apertura y concepto', href: '/consultoria/apertura/', desc: 'Del concepto a la puesta en marcha de tu restaurante.' },
  { label: 'Mentoría y acompañamiento', href: '/consultoria/mentoria/', desc: 'Sesiones recurrentes para chefs, propietarios y equipos de cocina.' },
];

const photo = { src: '/images/chef/andres-emplatando.jpg', alt: 'Andrés Valerio emplatando en cocina' };
const contextImage = { src: '/images/contexto/diagnostico.jpg', alt: 'Cuaderno de auditoría operativa y análisis de costos con la línea de cocina trabajando al fondo' };
---

<BaseLayout
  title={data.meta_title}
  description={data.meta_description}
  image="/og/og-default.jpg"
  canonicalPath={`/consultoria/${slug}/`}
>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={serviceSchema(data, slug, pricing.rows)} />
    <script type="application/ld+json" is:inline set:html={faqSchema(data.faq)} />
  </Fragment>

  <ServiceLanding slug={slug} data={data} photo={photo} pricing={pricing} related={related} contextImage={contextImage} />
</BaseLayout>

<script>
  import { initReveal } from '@utils/reveal';
  initReveal();
</script>
