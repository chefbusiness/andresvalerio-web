---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contacto · Andrés Valerio · Chef & Consultor"
  description="¿Tienes un proyecto en mente? Cuéntame qué necesitas y te preparo una propuesta a medida."
  canonicalPath="/contacto/"
>
  <section class="contact-hero">
    <div class="hero-photo" aria-hidden="true"></div>
    <div class="hero-scrim" aria-hidden="true"></div>
    <div class="container rv">
      <span class="eyebrow light">Contacto</span>
      <h1>¿Hablamos de tu proyecto?</h1>
      <p class="hero-lead">
        Cuéntame qué necesitas y te preparo una propuesta a medida.
        Respondo en menos de 48 horas.
      </p>
    </div>
  </section>

  <section class="contact-form-section section">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-info rv">
          <p class="eyebrow">Escríbeme</p>
          <h2>Otras formas de contacto</h2>
          <div class="contact-methods">
            <div class="contact-method">
              <span class="method-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 11.5a8.38 8.38 0 0 1-8.5 8.5 8.5 8.5 0 0 1-3.8-.9L3 21l1.9-5.7a8.5 8.5 0 0 1-.9-3.8A8.38 8.38 0 0 1 12.5 3 8.38 8.38 0 0 1 21 11.5z"/>
                </svg>
              </span>
              <div>
                <h3>WhatsApp</h3>
                <p>Escríbeme directo para consultas rápidas.</p>
                <a href="https://wa.me/18098847605" class="method-link" target="_blank" rel="noopener noreferrer">
                  Abrir WhatsApp →
                </a>
              </div>
            </div>
            <div class="contact-method">
              <span class="method-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="5" width="18" height="14" rx="2"/>
                  <path d="m3 7 9 6 9-6"/>
                </svg>
              </span>
              <div>
                <h3>Correo</h3>
                <p>Para propuestas formales y documentación.</p>
                <a href="mailto:hola@andresvalerio.com" class="method-link">
                  hola@andresvalerio.com
                </a>
              </div>
            </div>
            <div class="contact-method">
              <span class="method-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 10c0 5.5-8 12-8 12s-8-6.5-8-12a8 8 0 0 1 16 0z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
              </span>
              <div>
                <h3>Ubicación</h3>
                <p>Santo Domingo, República Dominicana.</p>
                <p class="method-note">Atiendo proyectos en todo el Caribe y LATAM.</p>
              </div>
            </div>
          </div>
        </div>

        <form
          name="contacto"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="contact-form rv"
        >
          <input type="hidden" name="form-name" value="contacto" />
          <p class="hidden">
            <label>No llenar si eres humano: <input name="bot-field" /></label>
          </p>

          <div class="form-group">
            <label for="nombre">Nombre</label>
            <input type="text" id="nombre" name="nombre" required placeholder="Tu nombre" />
          </div>

          <div class="form-group">
            <label for="email">Correo electrónico</label>
            <input type="email" id="email" name="email" required placeholder="tu@correo.com" />
          </div>

          <div class="form-group">
            <label for="tipo">Tipo de proyecto</label>
            <select id="tipo" name="tipo" required>
              <option value="">Seleccionar...</option>
              <option value="desarrollo-carta">Desarrollo de carta</option>
              <option value="apertura">Apertura y concepto</option>
              <option value="mentoria">Mentoría</option>
              <option value="diagnostico">Diagnóstico</option>
              <option value="otro">Otro</option>
            </select>
          </div>

          <div class="form-group">
            <label for="mensaje">Mensaje</label>
            <textarea id="mensaje" name="mensaje" rows="5" required placeholder="Cuéntame sobre tu proyecto..."></textarea>
          </div>

          <button type="submit" class="btn-primary btn-full">
            Enviar mensaje
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-hero {
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    min-height: clamp(58vh, 66vh, 620px);
    padding-top: calc(72px + var(--sec));
  }

  .contact-hero .container {
    position: relative;
    z-index: 1;
  }

  .hero-photo {
    position: absolute;
    inset: 0;
    z-index: -2;
    background-image: url(/images/chef/andres-emplatando.jpg);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    pointer-events: none;
  }

  .hero-scrim {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(
      180deg,
      rgba(13, 42, 39, 0.55),
      rgba(13, 42, 39, 0.82)
    );
    pointer-events: none;
  }

  .contact-hero h1 {
    font-size: clamp(2.7rem, 7vw, 5rem);
    line-height: 1;
    margin-top: 0.4em;
    color: var(--bone);
  }

  .hero-lead {
    font-size: clamp(1.1rem, 1.8vw, 1.3rem);
    color: var(--bone-soft);
    margin-top: 1.6rem;
    max-width: 50ch;
    line-height: 1.55;
  }

  .eyebrow.light {
    color: var(--brass);
  }

  .eyebrow.light::before {
    background: var(--brass);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr 1.2fr;
    }
  }

  .contact-info .eyebrow {
    color: var(--pers);
  }

  .contact-info .eyebrow::before {
    background: var(--pers);
  }

  .contact-info h2 {
    font-size: clamp(1.7rem, 3vw, 2.2rem);
    line-height: 1.1;
    margin: 0.3em 0 2rem;
    color: var(--ink);
  }

  .contact-methods {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact-method {
    display: flex;
    gap: 1.1rem;
    align-items: flex-start;
    padding: 1.25rem 1.35rem;
    background: var(--paper);
    border: 1px solid var(--line-light);
    border-radius: 8px;
    transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s;
  }

  .contact-method:hover {
    transform: translateY(-3px);
    box-shadow: 0 18px 40px -28px rgba(22, 36, 31, 0.4);
    border-color: rgba(221, 84, 48, 0.4);
  }

  .method-icon {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: var(--pers-soft);
    color: var(--pers-deep);
  }

  .method-icon svg {
    width: 22px;
    height: 22px;
  }

  .contact-method h3 {
    font-size: 1.05rem;
    font-family: var(--font-body);
    font-weight: 600;
    color: var(--ink);
  }

  .contact-method p {
    font-size: 0.95rem;
    color: var(--ink-soft);
    margin-top: 0.3rem;
    line-height: 1.5;
  }

  .method-link {
    display: inline-block;
    margin-top: 0.6rem;
    font-size: 0.875rem;
    color: var(--pers-deep);
    font-weight: 600;
    transition: color 0.2s;
  }

  .method-link:hover {
    text-decoration: underline;
  }

  .method-note {
    font-size: 0.75rem;
    color: var(--ink-soft);
    margin-top: 0.3rem;
  }

  .contact-form {
    background: var(--paper);
    padding: clamp(1.75rem, 3vw, 2.5rem);
    border-radius: 10px;
    border: 1px solid var(--line-light);
    box-shadow: 0 28px 60px -42px rgba(22, 36, 31, 0.45);
  }

  .form-group {
    margin-bottom: 1.35rem;
  }

  .form-group label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.6rem;
    color: var(--pers-deep);
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 0.8rem 1rem;
    font-family: var(--font-body);
    font-size: 0.9375rem;
    border: 1px solid var(--line-light);
    border-radius: 6px;
    background: var(--bone);
    color: var(--ink);
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--pers);
    box-shadow: 0 0 0 3px rgba(221, 84, 48, 0.15);
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: var(--ink-soft);
    opacity: 0.7;
  }

  .form-group textarea {
    resize: vertical;
    min-height: 130px;
  }

  .btn-full {
    width: 100%;
    justify-content: center;
    margin-top: 0.5rem;
  }

  .hidden {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }
</style>

<script>
  import { initReveal } from '@utils/reveal';
  initReveal();
</script>
