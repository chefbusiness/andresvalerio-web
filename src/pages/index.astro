---
import BaseLayout from '@layouts/BaseLayout.astro';
import { personSchema } from '@utils/schema';
---

<BaseLayout
  title="Andrés Valerio · Chef & Consultor Gastronómico"
  description="Chef-consultor en Santo Domingo. Desarrollo de cartas, apertura de conceptos y mentoría para equipos de cocina."
  canonicalPath="/"
>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={personSchema()} />
  </Fragment>
  <section class="hero">
    <div class="hero-photo" aria-hidden="true"></div>
    <div class="hero-scrim" aria-hidden="true"></div>
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="container">
      <div class="hero-content rv">
        <span class="eyebrow">Chef & Consultor</span>
        <h1>Andrés Valerio</h1>
        <p class="hero-lead">
          Cocina honesta, de carácter y empuje. Desarrollo de cartas, apertura de conceptos
          y mentoría para equipos de cocina en República Dominicana.
        </p>
        <div class="hero-ctas">
          <a href="/consultoria/" class="btn-primary">
            Ver consultoría
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="/sobre-mi/" class="btn-ghost">Conocer más</a>
        </div>
        <div class="hero-trust">
          <span>Chef-propietario de Valerio Burger Club</span>
          <span class="dot"></span>
          <span>Santo Domingo · Santiago · Punta Cana</span>
        </div>
      </div>
    </div>
  </section>

  <section class="intro section bg-teal">
    <div class="container">
      <div class="intro-grid rv">
        <div class="intro-text">
          <span class="eyebrow light">Quién es Andrés</span>
          <h2>De Venezuela a Santo Domingo</h2>
          <p>
            Más de 10 años de oficio. Alta cocina de calle: técnica de alta cocina
            aplicada a la cocina del día a día. Creador de Burger Master Academy
            y hoy chef-propietario de Valerio Burger Club.
          </p>
          <a href="/sobre-mi/" class="btn-ghost">Leer mi historia</a>
        </div>
        <div class="intro-stats">
          <div class="stat">
            <span class="stat-num">10+</span>
            <span class="stat-label">años de oficio</span>
          </div>
          <div class="stat">
            <span class="stat-num">3</span>
            <span class="stat-label">conceptos creados</span>
          </div>
          <div class="stat">
            <span class="stat-num">RD</span>
            <span class="stat-label">Santo Domingo</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <figure class="ctx-band">
    <img src="/images/contexto/cocina-valerio.jpg" alt="Andrés Valerio montando hamburguesas de autor bajo las lámparas de calor de su cocina" width="1400" height="934" loading="lazy" />
  </figure>

  <section class="consultoria section">
    <div class="container">
      <div class="sec-head rv">
        <span class="eyebrow">Servicios</span>
        <h2>Consultoría gastronómica</h2>
        <p>El mismo chef que diseña el plato es el que entrena a tu equipo.</p>
      </div>
      <div class="services-grid">
        <a href="/consultoria/desarrollo-carta/" class="service-card rv d1">
          <span class="service-num font-mono">01</span>
          <h3>Desarrollo de carta</h3>
          <p>Creación y renovación de menús con escandallos, fichas técnicas y entrenamiento.</p>
          <span class="service-arrow" aria-hidden="true">→</span>
        </a>
        <a href="/consultoria/apertura/" class="service-card rv d2">
          <span class="service-num font-mono">02</span>
          <h3>Apertura y concepto</h3>
          <p>Del concepto a la puesta en marcha: viabilidad, carta, flujo de cocina.</p>
          <span class="service-arrow" aria-hidden="true">→</span>
        </a>
        <a href="/consultoria/mentoria/" class="service-card rv d3">
          <span class="service-num font-mono">03</span>
          <h3>Mentoría</h3>
          <p>Sesiones recurrentes para chefs, propietarios y equipos de cocina.</p>
          <span class="service-arrow" aria-hidden="true">→</span>
        </a>
        <a href="/consultoria/diagnostico/" class="service-card rv d4">
          <span class="service-num font-mono">04</span>
          <h3>Diagnóstico</h3>
          <p>Auditoría 360°: operaciones, costos, carta, equipo y posicionamiento.</p>
          <span class="service-arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <section class="vbc section">
    <div class="container">
      <a href="https://valerioburgerclub.com" target="_blank" rel="noopener" class="vbc-card rv">
        <div class="vbc-glow" aria-hidden="true"></div>
        <div class="vbc-body">
          <span class="eyebrow">Chef-propietario</span>
          <h2>Valerio Burger Club</h2>
          <p class="vbc-lead">
            No solo asesoro: opero. Mi restaurante es donde la teoría se cocina cada día.
            Producto, costos, equipo y pase, vividos en primera persona.
          </p>
          <span class="vbc-link">
            Visitar Valerio Burger Club
            <span class="vbc-arrow" aria-hidden="true">→</span>
          </span>
          <p class="vbc-tagline font-mono">Pasión · técnica · fuego</p>
        </div>
        <div class="vbc-figure">
          <img src="/images/hero/andres-burger.jpg" alt="Andrés Valerio sosteniendo una hamburguesa de autor de Valerio Burger Club" width="1000" height="1250" loading="lazy" />
        </div>
      </a>
    </div>
  </section>

  <section class="cta-final section">
    <div class="cta-bg" aria-hidden="true"></div>
    <div class="cta-scrim" aria-hidden="true"></div>
    <div class="container cta-center rv">
      <span class="eyebrow light">¿Hablamos?</span>
      <h2>¿Tienes un proyecto en mente?</h2>
      <p>Cuéntame qué necesitas y te preparo una propuesta a medida.</p>
      <a href="/contacto/" class="btn-primary">
        Contactar
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    isolation: isolate; /* crea contexto de apilamiento: la foto (z-index:-2) se pinta sobre el fondo teal */
    display: flex;
    align-items: center;
    min-height: clamp(78vh, 86vh, 820px);
    padding-top: calc(72px + clamp(2rem, 6vw, 4rem));
    padding-bottom: clamp(3rem, 7vw, 5.5rem);
    background: var(--teal);
    overflow: hidden;
  }

  /* Foto a sangre completa de fondo (como el hero original) */
  .hero-photo {
    position: absolute;
    inset: 0;
    z-index: -2;
    background-image: url(/images/hero/andres-hero.jpg);
    background-size: cover;
    background-position: center 18%;
  }

  /* Scrim para legibilidad (refuerzo del lado del texto y en la base) */
  .hero-scrim {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(100deg, rgba(13, 42, 39, 0.94) 0%, rgba(13, 42, 39, 0.78) 30%, rgba(13, 42, 39, 0.42) 58%, rgba(13, 42, 39, 0.1) 100%),
      linear-gradient(180deg, rgba(13, 42, 39, 0.12), rgba(13, 42, 39, 0.55));
  }

  /* Glow sutil de marca + dotted-grid muy tenue sobre el scrim */
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
  }

  .hero-bg::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(243, 236, 221, 0.16) 1px, transparent 1px);
    background-size: 38px 38px;
    opacity: 0.35;
    mask-image: radial-gradient(120% 90% at 88% 10%, #000, transparent 68%);
  }

  .hero-bg::after {
    content: "";
    position: absolute;
    top: -14%;
    right: -8%;
    width: 50vw;
    height: 50vw;
    max-width: 560px;
    max-height: 560px;
    background: radial-gradient(circle, rgba(221, 84, 48, 0.22), transparent 66%);
  }

  .hero .container {
    position: relative;
    z-index: 1;
  }

  .hero-content {
    max-width: 640px;
  }

  .hero h1 {
    font-size: clamp(3rem, 8vw, 5rem);
    margin-top: 1rem;
    line-height: 1;
    color: var(--bone);
    text-shadow: 0 2px 24px rgba(13, 42, 39, 0.45);
  }

  .hero-lead {
    font-size: 1.25rem;
    color: var(--bone-soft);
    margin-top: 1.5rem;
    max-width: 50ch;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
    flex-wrap: wrap;
  }

  .hero-trust {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-top: 2.5rem;
    font-size: 0.86rem;
    color: var(--bone-soft);
    flex-wrap: wrap;
  }

  .hero-trust .dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--pers);
  }

  @media (max-width: 640px) {
    .hero {
      min-height: clamp(72vh, 78vh, 680px);
    }
    .hero-photo {
      background-position: center 12%;
    }
  }

  .ctx-band {
    margin: 0;
    overflow: hidden;
  }
  .ctx-band img {
    width: 100%;
    height: clamp(280px, 44vh, 520px);
    object-fit: cover;
    display: block;
  }

  .bg-teal {
    background: var(--teal);
    color: var(--bone);
  }

  .bg-teal .eyebrow {
    color: var(--brass);
  }

  .bg-teal .eyebrow::before {
    background: var(--brass);
  }

  .eyebrow.light {
    color: var(--brass);
  }

  .eyebrow.light::before {
    background: var(--brass);
  }

  .intro-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }

  @media (min-width: 768px) {
    .intro-grid {
      grid-template-columns: 1.5fr 1fr;
    }
  }

  .intro-text h2 {
    font-size: clamp(2rem, 4vw, 2.5rem);
    margin-top: 0.75rem;
    color: var(--bone);
  }

  .intro-text p {
    margin-top: 1rem;
    color: var(--bone-soft);
    max-width: 50ch;
  }

  .intro-text .btn-ghost {
    margin-top: 1.5rem;
  }

  .intro-stats {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .stat {
    display: flex;
    flex-direction: column;
  }

  .stat-num {
    font-family: var(--font-display);
    font-size: 2.5rem;
    color: var(--brass);
    line-height: 1;
  }

  .stat-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--bone-soft);
    margin-top: 0.5rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .service-card {
    background: var(--paper);
    padding: 2rem;
    border-radius: 8px;
    border: 1px solid var(--line-light);
    transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s;
    text-decoration: none;
    color: inherit;
    position: relative;
  }

  .service-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 24px 50px -30px rgba(22, 36, 31, 0.4);
    border-color: rgba(221, 84, 48, 0.45);
  }

  .service-num {
    font-size: 0.75rem;
    color: var(--pers-deep);
    letter-spacing: 0.1em;
  }

  .service-card h3 {
    font-size: 1.5rem;
    margin-top: 0.5rem;
  }

  .service-card p {
    margin-top: 0.75rem;
    font-size: 1rem;
    color: var(--ink-soft);
  }

  .service-arrow {
    display: inline-block;
    margin-top: 1.25rem;
    color: var(--pers);
    font-size: 1.2rem;
    transition: transform 0.3s;
  }

  .service-card:hover .service-arrow {
    transform: translateX(6px);
  }

  .vbc {
    background: var(--bone-2);
  }

  .vbc-card {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: stretch;
    background: var(--teal);
    color: var(--bone);
    border: 1px solid var(--line-dark);
    border-radius: 12px;
    padding: clamp(36px, 5vw, 64px);
    overflow: hidden;
    text-decoration: none;
    transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s;
  }

  @media (min-width: 768px) {
    .vbc-card {
      grid-template-columns: 1.7fr 1fr;
    }
  }

  .vbc-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 28px 60px -32px rgba(22, 36, 31, 0.6);
    border-color: rgba(221, 84, 48, 0.55);
  }

  .vbc-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(120% 90% at 86% 6%, rgba(221, 84, 48, 0.26), transparent 58%);
    pointer-events: none;
  }

  .vbc-body {
    position: relative;
    max-width: 52ch;
    display: flex;
    flex-direction: column;
  }

  .vbc-figure {
    position: relative;
    z-index: 1;
    align-self: stretch;
    min-height: 260px;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--line-dark);
  }
  .vbc-figure img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .vbc-card .eyebrow {
    color: var(--pers);
  }

  .vbc-card .eyebrow::before {
    background: var(--pers);
  }

  .vbc-card h2 {
    font-size: clamp(2rem, 4.6vw, 3.2rem);
    margin-top: 0.75rem;
    color: var(--bone);
    line-height: 1;
  }

  .vbc-lead {
    margin-top: 1.25rem;
    color: var(--bone-soft);
  }

  .vbc-link {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    margin-top: 1.75rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--brass);
  }

  .vbc-arrow {
    display: inline-block;
    transition: transform 0.3s;
  }

  .vbc-card:hover .vbc-arrow {
    transform: translateX(6px);
  }

  .vbc-tagline {
    position: relative;
    margin-top: 2rem;
    font-size: 0.82rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--pers);
    text-align: left;
  }

  .cta-final {
    position: relative;
    isolation: isolate;
    overflow: hidden;
  }
  .cta-bg {
    position: absolute;
    inset: 0;
    z-index: -2;
    background-image: url(/images/cta/fuego.jpg);
    background-size: cover;
    background-position: center;
    background-attachment: fixed; /* parallax en desktop */
  }
  .cta-scrim {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      radial-gradient(70% 90% at 50% 45%, rgba(13, 42, 39, 0.55), rgba(13, 42, 39, 0.82)),
      linear-gradient(180deg, rgba(13, 42, 39, 0.7), rgba(13, 42, 39, 0.88));
  }
  @media (max-width: 880px) {
    /* iOS ignora background-attachment: fixed → fondo estático en móvil */
    .cta-bg { background-attachment: scroll; }
  }

  .cta-center {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .cta-center h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-top: 0.75rem;
    color: var(--bone);
  }

  .cta-center p {
    margin-top: 1rem;
    color: var(--bone-soft);
    max-width: 40ch;
  }

  .cta-center .btn-primary {
    margin-top: 2rem;
  }
</style>

<script>
  import { initReveal } from '@utils/reveal';
  initReveal();
</script>
