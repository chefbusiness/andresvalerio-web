---
import BaseLayout from '@layouts/BaseLayout.astro';
interface Props { title: string; updated?: string; description?: string; canonicalPath: string; }
const { title, updated, description, canonicalPath } = Astro.props;
---

<BaseLayout title={`${title} · Andrés Valerio`} description={description} canonicalPath={canonicalPath}>
  <section class="legal-hero">
    <div class="container">
      <p class="crumb font-mono"><a href="/">Inicio</a> &nbsp;/&nbsp; <strong>{title}</strong></p>
      <h1>{title}</h1>
      {updated && <p class="updated font-mono">Última actualización: {updated}</p>}
    </div>
  </section>
  <section class="section">
    <div class="container">
      <div class="legal-prose"><slot /></div>
    </div>
  </section>
</BaseLayout>

<style>
  .legal-hero {
    background: var(--teal);
    color: var(--bone);
    padding: calc(72px + clamp(2rem, 6vw, 3.5rem)) 0 clamp(2rem, 5vw, 3rem);
  }
  .crumb { font-size: 0.72rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--bone-soft); margin-bottom: 18px; }
  .crumb a { color: var(--bone-soft); }
  .crumb strong { color: var(--pers); font-weight: 500; }
  .legal-hero h1 { font-size: clamp(2.2rem, 5vw, 3.4rem); color: var(--bone); line-height: 1.05; }
  .updated { margin-top: 12px; font-size: 0.74rem; letter-spacing: 0.05em; color: var(--bone-soft); }

  .legal-prose { max-width: 760px; }
  .legal-prose :global(h2) { font-size: clamp(1.3rem, 2.4vw, 1.7rem); color: var(--ink); margin: 2.2rem 0 0.6rem; }
  .legal-prose :global(p) { color: var(--ink-soft); line-height: 1.8; margin-bottom: 1rem; }
  .legal-prose :global(ul) { padding-left: 1.25rem; margin-bottom: 1rem; }
  .legal-prose :global(li) { color: var(--ink-soft); line-height: 1.7; margin-bottom: 0.5rem; }
  .legal-prose :global(a) { color: var(--pers-deep); }
  .legal-prose :global(strong) { color: var(--ink); }
</style>
