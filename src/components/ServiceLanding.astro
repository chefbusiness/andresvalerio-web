---
// Plantilla reutilizable para las landings de servicio de consultoría.
// Arquitectura de secciones según la guía maestra (§6.3):
// hero → para quién → método → qué incluye → ejemplo → precios → autoridad → FAQ → CTA.
// Inyecta Schema.org Service + FAQPage vía <slot name="head">.

interface Faq { q: string; a: string; }
interface TitleDesc { title: string; desc: string; }
interface PricingRow { modalidad: string; alcance: string; rd: string; us: string; feat?: boolean; }
interface RelatedLink { label: string; href: string; desc: string; }

export interface ServiceData {
  meta_title: string;
  meta_description: string;
  hero: { eyebrow: string; h1: string; lead: string };
  para_quien: TitleDesc[];
  metodo_intro: string;
  metodo: TitleDesc[];
  incluye: string[];
  ejemplo: { quote: string; desc: string };
  autoridad: string;
  faq: Faq[];
  cta: { h2: string; text: string };
}

interface Props {
  slug: string;
  data: ServiceData;
  photo: { src: string; alt: string };
  pricing: { title: string; rows: PricingRow[]; note: string };
  related: RelatedLink[];
}

const { slug, data, photo, pricing, related } = Astro.props;
void slug;
---

<!-- HERO -->
<section class="svc-hero section">
  <div class="container">
    <p class="crumb font-mono rv">
      <a href="/consultoria/">Consultoría</a> &nbsp;/&nbsp; <strong>{data.hero.eyebrow}</strong>
    </p>
    <span class="eyebrow rv d1">{data.hero.eyebrow}</span>
    <h1 class="rv d2" set:html={data.hero.h1} />
    <p class="lead rv d3">{data.hero.lead}</p>
    <div class="hero-ctas rv d4">
      <a href="/contacto/" class="btn-primary">
        Solicitar propuesta
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href="#metodo" class="btn-dark">Ver cómo trabajo ↓</a>
    </div>
  </div>
</section>

<!-- PARA QUIÉN -->
<section class="section bg-teal">
  <div class="container">
    <div class="sec-head rv">
      <span class="eyebrow light">Para quién</span>
      <h2>Pensado para quien vive del producto</h2>
    </div>
    <div class="aud-grid">
      {data.para_quien.map((p, i) => (
        <div class:list={['aud', 'rv', `d${(i % 4) + 1}`]}>
          <span class="aud-n font-mono">{String(i + 1).padStart(2, '0')}</span>
          <h3>{p.title}</h3>
          <p>{p.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- MÉTODO -->
<section class="section" id="metodo">
  <div class="container">
    <div class="sec-head rv">
      <span class="eyebrow">El método</span>
      <h2>Cómo trabajo, paso a paso</h2>
      <p>{data.metodo_intro}</p>
    </div>
    <div class="steps">
      {data.metodo.map((s, i) => (
        <div class:list={['step', 'rv', i % 2 ? 'd1' : '']}>
          <span class="step-n font-mono">{String(i + 1).padStart(2, '0')}</span>
          <h3>{s.title}</h3>
          <p>{s.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- QUÉ INCLUYE -->
<section class="section bg-teal">
  <div class="container">
    <div class="incluye-grid">
      <div class="rv">
        <span class="eyebrow light">Qué incluye</span>
        <h2>Lo que recibes</h2>
      </div>
      <ul class="incluye-list rv d1">
        {data.incluye.map((item) => (
          <li>
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M3.5 9.5l3.5 3.5 7.5-8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<!-- EJEMPLO -->
<section class="section">
  <div class="container">
    <div class="case rv">
      <span class="eyebrow">Un encargo típico</span>
      <p class="case-quote">{data.ejemplo.quote}</p>
      <p class="case-desc">{data.ejemplo.desc}</p>
    </div>
  </div>
</section>

<!-- PRECIOS -->
<section class="section bg-teal">
  <div class="container">
    <div class="sec-head rv">
      <span class="eyebrow light">Inversión</span>
      <h2>{pricing.title}</h2>
    </div>
    <div class="price-table rv">
      <table>
        <thead>
          <tr><th>Modalidad</th><th>Alcance</th><th>RD$</th><th>US$</th></tr>
        </thead>
        <tbody>
          {pricing.rows.map((r) => (
            <tr class:list={[{ feat: r.feat }]}>
              <td data-label="Modalidad"><strong>{r.modalidad}</strong></td>
              <td data-label="Alcance">{r.alcance}</td>
              <td data-label="RD$" class="font-mono">{r.rd}</td>
              <td data-label="US$" class="font-mono">{r.us}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="price-note rv">{pricing.note}</p>
  </div>
</section>

<!-- AUTORIDAD -->
<section class="section">
  <div class="container">
    <div class="authority rv">
      <div class="authority-text">
        <span class="eyebrow">Por qué Andrés</span>
        <h2>Quien diseña, ejecuta y entrena</h2>
        <p>{data.autoridad}</p>
        <a href="/sobre-mi/" class="btn-dark">Conocer mi historia</a>
      </div>
      <img src={photo.src} alt={photo.alt} width="900" height="1125" loading="lazy" class="authority-photo" />
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="section bg-teal">
  <div class="container">
    <div class="sec-head rv">
      <span class="eyebrow light">Preguntas frecuentes</span>
      <h2>Lo que suelen preguntarme</h2>
    </div>
    <div class="faq rv">
      {data.faq.map((f) => (
        <details class="q">
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<!-- OTROS SERVICIOS (interenlazado) -->
<section class="section">
  <div class="container">
    <div class="sec-head rv">
      <span class="eyebrow">Sigue explorando</span>
      <h2>Otros servicios de consultoría</h2>
    </div>
    <div class="related-grid">
      {related.map((r, i) => (
        <a href={r.href} class:list={['related-card', 'rv', `d${(i % 3) + 1}`]}>
          <h3>{r.label}</h3>
          <p>{r.desc}</p>
          <span class="related-arrow">→</span>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- CTA FINAL -->
<section class="section bg-teal" id="contacto">
  <div class="container cta-center rv">
    <span class="eyebrow light">¿Hablamos?</span>
    <h2>{data.cta.h2}</h2>
    <p>{data.cta.text}</p>
    <a href="/contacto/" class="btn-primary">
      Solicitar propuesta
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </div>
</section>

<style>
  .svc-hero {
    padding-top: calc(72px + var(--sec));
  }
  .crumb {
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-bottom: 1.25rem;
  }
  .crumb a:hover { color: var(--pers); }
  .svc-hero h1 {
    font-size: clamp(2.4rem, 5.5vw, 4rem);
    margin-top: 1rem;
    max-width: 18ch;
  }
  .svc-hero h1 :global(em) {
    font-style: italic;
    color: var(--pers);
  }
  .lead {
    font-size: 1.25rem;
    color: var(--ink-soft);
    margin-top: 1.5rem;
    max-width: 60ch;
  }
  .hero-ctas {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
    flex-wrap: wrap;
  }

  .bg-teal { background: var(--teal); color: var(--bone); }
  .bg-teal :global(h2) { color: var(--bone); }
  .eyebrow.light { color: var(--brass); }
  .eyebrow.light::before { background: var(--brass); }

  /* Para quién */
  .aud-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 640px) { .aud-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 980px) { .aud-grid { grid-template-columns: repeat(4, 1fr); } }
  .aud {
    background: var(--teal-2);
    padding: 1.5rem;
    border-radius: 8px;
    border: 1px solid rgba(243, 236, 221, 0.08);
  }
  .aud-n { font-size: 0.75rem; color: var(--brass); }
  .aud h3 { font-size: 1.2rem; margin-top: 0.75rem; color: var(--bone); }
  .aud p { margin-top: 0.5rem; font-size: 0.875rem; color: var(--bone-soft); }

  /* Método */
  .steps {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 640px) { .steps { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 980px) { .steps { grid-template-columns: repeat(3, 1fr); } }
  .step {
    background: var(--paper);
    padding: 1.75rem;
    border-radius: 8px;
    border: 1px solid rgba(22, 36, 31, 0.06);
    border-top: 2px solid var(--pers);
  }
  .step-n { font-size: 0.875rem; color: var(--pers); }
  .step h3 { font-size: 1.25rem; margin-top: 0.5rem; }
  .step p { margin-top: 0.5rem; font-size: 0.9375rem; color: var(--ink-soft); }

  /* Qué incluye */
  .incluye-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media (min-width: 768px) { .incluye-grid { grid-template-columns: 1fr 1.4fr; gap: 4rem; align-items: start; } }
  .incluye-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 1rem; }
  .incluye-list li { display: flex; gap: 0.75rem; align-items: flex-start; color: var(--bone-soft); }
  .incluye-list svg { color: var(--brass); flex-shrink: 0; margin-top: 2px; }

  /* Ejemplo */
  .case {
    background: linear-gradient(135deg, var(--paper), rgba(221, 84, 48, 0.04));
    border: 1px solid rgba(22, 36, 31, 0.06);
    border-left: 3px solid var(--pers);
    border-radius: 8px;
    padding: clamp(1.75rem, 4vw, 3rem);
  }
  .case-quote {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.35rem, 2.6vw, 1.9rem);
    line-height: 1.4;
    margin-top: 1rem;
    color: var(--ink);
  }
  .case-desc { margin-top: 1rem; color: var(--ink-soft); max-width: 60ch; }

  /* Precios */
  .price-table { overflow-x: auto; border-radius: 8px; }
  .price-table table { width: 100%; border-collapse: collapse; background: var(--teal-2); border-radius: 8px; overflow: hidden; }
  .price-table th, .price-table td { padding: 1rem 1.25rem; text-align: left; border-bottom: 1px solid rgba(243, 236, 221, 0.08); }
  .price-table th { font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--brass); }
  .price-table td { color: var(--bone-soft); font-size: 0.9375rem; }
  .price-table td strong { color: var(--bone); }
  .price-table tr.feat td { background: rgba(221, 84, 48, 0.12); }
  .price-note { margin-top: 1.25rem; font-size: 0.8125rem; color: var(--bone-faint); max-width: 70ch; }

  /* Autoridad */
  .authority { display: grid; grid-template-columns: 1fr; gap: 2.5rem; align-items: center; }
  @media (min-width: 768px) { .authority { grid-template-columns: 1.4fr 1fr; } }
  .authority h2 { font-size: clamp(2rem, 4vw, 2.5rem); margin-top: 0.75rem; }
  .authority-text p { margin-top: 1rem; color: var(--ink-soft); max-width: 55ch; }
  .authority-text .btn-dark { margin-top: 1.5rem; }
  .authority-photo { width: 100%; aspect-ratio: 4/5; object-fit: cover; border-radius: 10px; box-shadow: 0 20px 50px rgba(22, 36, 31, 0.2); }

  /* FAQ */
  .faq { max-width: 800px; }
  .q { border-bottom: 1px solid rgba(243, 236, 221, 0.14); }
  .q summary {
    list-style: none;
    cursor: pointer;
    padding: 1.25rem 0;
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--bone);
    display: flex;
    justify-content: space-between;
    gap: 1rem;
  }
  .q summary::-webkit-details-marker { display: none; }
  .q summary::after { content: '+'; color: var(--brass); font-family: var(--font-body); flex-shrink: 0; transition: transform 0.2s; }
  .q[open] summary::after { content: '−'; }
  .q p { padding: 0 0 1.25rem; color: var(--bone-soft); max-width: 70ch; }

  /* Related */
  .related-grid { display: grid; grid-template-columns: 1fr; gap: 1.5rem; }
  @media (min-width: 768px) { .related-grid { grid-template-columns: repeat(3, 1fr); } }
  .related-card {
    background: var(--paper);
    padding: 1.75rem;
    border-radius: 8px;
    border: 1px solid rgba(22, 36, 31, 0.06);
    transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
    position: relative;
  }
  .related-card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(22, 36, 31, 0.08); border-color: var(--brass); }
  .related-card h3 { font-size: 1.25rem; }
  .related-card p { margin-top: 0.5rem; font-size: 0.9375rem; color: var(--ink-soft); }
  .related-arrow { color: var(--pers); font-size: 1.25rem; display: inline-block; margin-top: 0.75rem; }

  /* CTA */
  .cta-center { text-align: center; display: flex; flex-direction: column; align-items: center; }
  .cta-center h2 { font-size: clamp(2rem, 4vw, 3rem); margin-top: 0.75rem; }
  .cta-center p { margin-top: 1rem; color: var(--bone-soft); max-width: 45ch; }
  .cta-center .btn-primary { margin-top: 2rem; }
</style>
